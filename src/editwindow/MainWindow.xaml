<Window x:Class="editwindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:editwindow"
        mc:Ignorable="d"
        Title="NavigatorHMI" Height="450" Width="800">
    <Grid ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="1" ShowGridLines="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            <TreeView Grid.Row="0" Grid.Column="0">
                <TreeViewItem Header="画面列表" IsSelected="True">
                    <TreeViewItem Header="全局显示"/>
                    <TreeViewItem Header="地图画面"/>
                    <TreeViewItem Header="画面1" IsSelected ="True"/>
                </TreeViewItem>
                <TreeViewItem Header="变量列表">
                    <TreeViewItem Header="变量"/>
                    <TreeViewItem Header="加载图像"/>
                    <TreeViewItem Header="加载文本"/>
                </TreeViewItem>
                <TreeViewItem Header="连接列表">
                    <TreeViewItem Header="串口设置"/>
                    <TreeViewItem Header="网络设置"/>
                </TreeViewItem>
            </TreeView>
            <Border Grid.Row="1" Grid.Column="1" BorderBrush="Black" BorderThickness="2" Margin="3">
                <Canvas x:Name="drawingCanvas" Background="White" />
                <!-- MouseLeftButtonDown="DrawingCanvas_MouseLeftButtonDown" -->
            </Border>
            <TabControl Grid.Row="1" Grid.Column="2"  TabStripPlacement="Top">
                <TabItem Header="一般控件">
                    <StackPanel Orientation="Vertical">
                        <Button Content="Point"/>
                        <Button Content="Line" />
                        <Button Content="Label"/>
                        <Button Content="Button"/>
                        <Button Content="Rectange"/>
                        <Button Content="Circle"/>
                        <Button Content="IOField"/>
                        <Button Content="Frame"/>
                        <Button Content="CheckBox"/>
                        <Button Content="TextBox"/>
                    </StackPanel>
                </TabItem>
                <TabItem Header="窗口控件">
                    <StackPanel Orientation="Vertical">
                        <Button Content="User View"/>
                        <Button Content="Alarm View"/>
                        <Button Content="Robot List"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>

        <Menu HorizontalAlignment="Left">
            <MenuItem Header="文件">
                <MenuItem Header="新建"/>
                <MenuItem Header="打开"/>
                <MenuItem Header="保存"/>
                <MenuItem Header="另存为"/>
                <MenuItem Header="关闭工程"/>
            </MenuItem>
            <MenuItem Header="编辑">
                <MenuItem Header="撤销"/>
            </MenuItem>
            <MenuItem Header="视图">
                <MenuItem Header="恢复默认布局"/>
            </MenuItem>
        </Menu>
    </Grid>
</Window>
