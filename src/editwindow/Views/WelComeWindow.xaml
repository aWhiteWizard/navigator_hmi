<Window x:Class="NavigatorHMI.Views.WelComeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NavigatorHMI"
        mc:Ignorable="d"
        Height="440" Width="620"
        ResizeMode="NoResize"
        Loaded="WelComeWindowLoaded">
    <Grid Background="White" ShowGridLines="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="340"/>
        </Grid.RowDefinitions>
                <Grid Grid.Row="0" ShowGridLines="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/> 
            </Grid.ColumnDefinitions>
            <Image Grid.Column="1" Source="F:\code\navigator_hmi\src\picture\未来科技工坊_白底蓝花.png"></Image>
            <Label Grid.Column="0" Content="NavigatorHMI" HorizontalAlignment="Left" Margin="20,0,0,20" VerticalAlignment="Center" FontSize="24" FontWeight="Black"/>
        </Grid>
        <Grid Grid.Row="1" ShowGridLines="False" Height="340">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Line X1="400" Y1="0" X2="400" Y2="340"  Stroke="Gray" StrokeThickness="1" StrokeDashArray="2,2"/>
            <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="180">
                <Button Height="40" Margin="0,5,0,0" Click="CreateNewProject_Click">新建工程</Button>
                <Button Height="40" Margin="0,5,0,0" Click="OpenProject_Click">打开本地工程</Button>
            </StackPanel>

            <Grid Grid.Column="0" ShowGridLines="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Content="打开最近编辑的文档" HorizontalAlignment="Left" Margin="20,0,0,0" VerticalAlignment="Center" FontSize="18" />
                <Button HorizontalAlignment="Right" Width="20" Height="20" Margin="0,0,20,0" Click="ClearInvalidProjects_Click"/>
                <ListBox x:Name="RecentProjectsListBox" 
                    Grid.Row="2" Width="370" Margin="20,20,10,20" 
                    BorderBrush="White" 
                    HorizontalAlignment="Left"
                    SelectionChanged="RecentProjectsListBox_SelectionChanged">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <!-- 名称：文件不存在时变灰+删除线 -->
                                <TextBlock Text="{Binding Name}" FontWeight="Bold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="Black"/>
                                            <Setter Property="TextDecorations" Value="None"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFileExists}" Value="False">
                                                    <Setter Property="Foreground" Value="Gray"/>
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- 路径：文件不存在时也变灰（可选） -->
                                <TextBlock Text="{Binding Path}" FontSize="10" Foreground="Gray">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsFileExists}" Value="False">
                                                    <Setter Property="Foreground" Value="LightGray"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- 时间：不变，保持原样 -->
                                <TextBlock Text="{Binding LastOpenedTime}" FontSize="9" Foreground="DarkGray"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</Window>
