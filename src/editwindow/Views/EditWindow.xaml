<Window x:Class="NavigatorHMI.Views.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NavigatorHMI"
        xmlns:vm="clr-namespace:NavigatorHMI.ViewModels"
        mc:Ignorable="d"
        Closing="EditWindow_Closing"
        Title="NavigatorHMI" Height="450" Width="800">
    <Window.Resources>
        <!-- 5x5 点阵画刷 -->
        <DrawingBrush x:Key="DotGridBrush" 
                      TileMode="Tile" 
                      Viewport="0,0,5,5" 
                      ViewportUnits="Absolute">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <!-- 白色背景（可选，如果画布本身是白色可以省略） -->
                    <GeometryDrawing Geometry="M0,0 L5,0 L5,5 L0,5 Z" Brush="Gainsboro"/>
                    <!-- 浅灰色点 -->
                    <GeometryDrawing Geometry="M2.5,2.5 A0.5,0.5 0 1,1 2.5,2.4" Brush="Black"/>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>
    <Grid ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <!--  第一行：菜单栏  -->
        <Grid Grid.Row="0" ShowGridLines="True">
            <Menu HorizontalAlignment="Left">
                <MenuItem Header="文件">
                    <MenuItem Header="新建"/>
                    <MenuItem Header="打开"/>
                    <MenuItem Header="保存" Click="SaveCurrentProject_Click"/>
                    <MenuItem Header="另存为"/>
                    <MenuItem Header="关闭工程" Click="CloseCurrentProject_Click"/>
                </MenuItem>
                <MenuItem Header="保存" Click="SaveCurrentProject_Click"/>
                <MenuItem Header="编辑">
                    <MenuItem Header="撤销"/>
                </MenuItem>
                <MenuItem Header="视图">
                    <MenuItem Header="恢复默认布局"/>
                </MenuItem>
            </Menu>
        </Grid>
        
        <!--  第二行：工作空间  -->
        <Grid Grid.Row="1" ShowGridLines="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            
            <!--  第一列：项目属性  -->
            <Grid Grid.Column="0">
                <!-- 左侧工程树 -->
                <TreeView Grid.Column="0" 
                  x:Name="ProjectTreeView"
                  ItemsSource="{Binding TreeRoots}"
                  BorderBrush="LightGray"
                  PreviewKeyDown="ProjectTreeView_PreviewKeyDown">
                    <TreeView.Resources>
                        <!-- 普通画面节点 -->
                        <HierarchicalDataTemplate DataType="{x:Type vm:ScreenItemNode}" 
                                          ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" />
                        </HierarchicalDataTemplate>

                        <!-- 自定义画面列表根节点 -->
                        <HierarchicalDataTemplate DataType="{x:Type vm:CustomScreensRootNode}" 
                                          ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                        </HierarchicalDataTemplate>

                        <!-- 添加画面按钮节点 -->
                        <DataTemplate DataType="{x:Type vm:AddScreenNode}">
                            <TextBlock Text="{Binding Name}" Foreground="Green" Cursor="Hand" />
                        </DataTemplate>
                    </TreeView.Resources>

                    <!-- 为每个树节点附加双击事件 -->
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_DoubleClick"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>

            <!-- 第二列：画布区域 -->
            <Grid Grid.Column="1">
                <Border BorderBrush="Black" Background="Gray" BorderThickness="2" Margin="3" x:Name="canvasContainer">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <Canvas x:Name="DrawingCanvas"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Background="{StaticResource DotGridBrush}"
                                Width="{Binding DeviceWidth}" 
                                Height="{Binding DeviceHeight}"
                                MouseLeftButtonDown="Canvas_MouseLeftButtonDown">
                            <!-- 动态控件会添加到这里 -->
                            
                            <!-- 调试信息：当前画面名称 -->
                            <TextBlock Text="{Binding CurrentScreen.Name, FallbackValue=未选择画面}"
                               FontSize="14" FontWeight="Bold" 
                               Foreground="Red" Background="#80FFFFFF"
                               Padding="5" Margin="5"
                               Canvas.Left="5" Canvas.Top="5"
                               Panel.ZIndex="1000"/>
                        </Canvas>
                    </ScrollViewer>
                </Border>
            </Grid>
            <!-- 第二列结尾：画布区域 -->
            
            <!-- 第三列：控件面板 -->
            <Grid Grid.Column="2">
                <TabControl Grid.Row="1" Grid.Column="2"  TabStripPlacement="Top">
                    <TabItem Header="一般控件">
                        <StackPanel Orientation="Vertical">
                            <Button Content="Point"/>
                            <Button Content="Line" />
                            <Button Content="Label"/>
                            <Button x:Name="AddButtonModeBtn" 
                                    Content="Button"
                                    Click="ToggleAddButtonMode"/>
                             <Button Content="Rectange"/>
                            <Button Content="Circle"/>
                            <Button Content="IOField"/>
                            <Button Content="Frame"/>
                            <Button Content="CheckBox"/>
                            <Button Content="TextBox"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="窗口控件">
                        <StackPanel Orientation="Vertical">
                            <Button Content="User View"/>
                            <Button Content="Alarm View"/>
                            <Button Content="Robot List"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid><!-- 第三列结尾：控件面板 -->
        </Grid><!-- 第二行结尾-->
    </Grid>
</Window>
