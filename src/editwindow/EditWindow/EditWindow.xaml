<Window x:Class="NavigatorHMI.EditWindow.EditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:NavigatorHMI"
        mc:Ignorable="d"
        Title="NavigatorHMI" Height="450" Width="800">
    <Grid ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>
        <!--  第一行：菜单栏  -->
        <Grid Grid.Row="0" ShowGridLines="True">
            <Menu HorizontalAlignment="Left">
                <MenuItem Header="文件">
                    <MenuItem Header="新建"/>
                    <MenuItem Header="打开"/>
                    <MenuItem Header="保存"/>
                    <MenuItem Header="另存为"/>
                    <MenuItem Header="关闭工程"/>
                </MenuItem>
                <MenuItem Header="编辑">
                    <MenuItem Header="撤销"/>
                </MenuItem>
                <MenuItem Header="视图">
                    <MenuItem Header="恢复默认布局"/>
                </MenuItem>
            </Menu>
        </Grid>
        
        <!--  第二行：工作空间  -->
        <Grid Grid.Row="1" ShowGridLines="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="150"/>
            </Grid.ColumnDefinitions>
            
            <!--  第一列：项目属性  -->
            <Grid Grid.Column="0">
                <TreeView Grid.Row="0" Grid.Column="0">
                    <!-- 右键菜单资源 -->
                    <TreeView.Resources>
                        <ContextMenu x:Key="SceneContextMenu" x:Shared="False">
                            <MenuItem Header="剪切" Click="CutScene_Click">
                            </MenuItem>
                            <MenuItem Header="复制" Click="CopyScene_Click">
                            </MenuItem>
                            <MenuItem Header="粘贴" Click="PasteScene_Click" Name="PasteMenuItem">
                            </MenuItem>
                            <!--
                            <Separator/>
                            <MenuItem Header="重命名" Click="RenameScene_Click">
                            </MenuItem>
                            <MenuItem Header="删除" Click="DeleteScene_Click">
                            </MenuItem>-->
                        </ContextMenu>
                    </TreeView.Resources>

                    <TreeViewItem Header="画面列表" IsSelected="True">
                        <TreeViewItem x:Name="addScreenItem" Header="添加画面">
                            <TreeViewItem.Tag>AddNewScreen</TreeViewItem.Tag>
                        </TreeViewItem>
                        <TreeViewItem Header="全局显示"/>
                        <TreeViewItem Header="地图画面" IsSelected ="True"/>
                        <TreeViewItem Header="自定义画面">
                            <TreeViewItem Header="画面1" ContextMenu="{StaticResource SceneContextMenu}" MouseDoubleClick="ScreenTreeView_MouseDoubleClick">
                                <TreeViewItem.Tag>Scene1</TreeViewItem.Tag>
                            </TreeViewItem>
                        </TreeViewItem>
                    </TreeViewItem>
                    <TreeViewItem Header="变量列表">
                        <TreeViewItem Header="变量"/>
                        <TreeViewItem Header="加载图像"/>
                        <TreeViewItem Header="加载文本"/>
                    </TreeViewItem>
                    <TreeViewItem Header="连接列表">
                        <TreeViewItem Header="串口设置"/>
                        <TreeViewItem Header="网络设置"/>
                    </TreeViewItem>
                </TreeView>
            </Grid>

            <!-- 第二列：画布区域 -->
            <Grid Grid.Column="1">
                <Border BorderBrush="Black" BorderThickness="2" Margin="3" x:Name="canvasContainer">
                    <!-- 初始画布 -->
                    <Canvas x:Name="CanvasScene1" Background="White" 
                           Visibility="Visible">
                        <TextBlock Text="画面1" Foreground="LightGray" FontSize="36" 
                                  Canvas.Left="50" Canvas.Top="50"/>
                    </Canvas>
                </Border>
            </Grid><!-- 第二列结尾：画布区域 -->
            
            <!-- 第三列：控件面板 -->
            <Grid Grid.Column="2">
                <TabControl Grid.Row="1" Grid.Column="2"  TabStripPlacement="Top">
                    <TabItem Header="一般控件">
                        <StackPanel Orientation="Vertical">
                            <Button Content="Point"/>
                            <Button Content="Line" />
                            <Button Content="Label"/>
                            <Button Content="Button"/>
                            <Button Content="Rectange"/>
                            <Button Content="Circle"/>
                            <Button Content="IOField"/>
                            <Button Content="Frame"/>
                            <Button Content="CheckBox"/>
                            <Button Content="TextBox"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="窗口控件">
                        <StackPanel Orientation="Vertical">
                            <Button Content="User View"/>
                            <Button Content="Alarm View"/>
                            <Button Content="Robot List"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid><!-- 第三列结尾：控件面板 -->
        </Grid><!-- 第二行结尾-->
    </Grid>
</Window>
