<Window x:Class="navigator_hmi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:navigator_hmi"
        mc:Ignorable="d"
        Height="440" Width="620"
        ResizeMode="NoResize">
    <Grid Background="White" ShowGridLines="False">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="340"/>
        </Grid.RowDefinitions>
                <Grid Grid.Row="0" ShowGridLines="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="*"/> 
            </Grid.ColumnDefinitions>
            <Image Grid.Column="1" Source="F:\code\navigator_hmi\src\picture\welcome.PNG"></Image>
            <Label Grid.Column="0" Content="NavigatorHMI" HorizontalAlignment="Left" Margin="20,0,0,20" VerticalAlignment="Center" FontSize="24" FontWeight="Black"/>
        </Grid>
        <Grid Grid.Row="1" ShowGridLines="False" Height="340">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Left" Width="180">
                <Button Height="40" Margin="0,5,0,0">新建工程</Button>
                <Button Height="40" Margin="0,5,0,0">打开本地工程</Button>
            </StackPanel>

            <Grid Grid.Column="0" ShowGridLines="False">
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Content="打开最近编辑的文档" HorizontalAlignment="Left" Margin="20,0,0,0" VerticalAlignment="Center" FontSize="18" />
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <TextBox Width="300" HorizontalAlignment="Left" Margin="20,0,0,0"></TextBox>
                </StackPanel>
                <ListBox Grid.Row="2" Width="300" Margin="20,20,10,10" BorderBrush="White" HorizontalAlignment="Left">
                    <ListBoxItem Content="Document1.txt"/>
                    <ListBoxItem Content="Document2.txt"/>
                    <ListBoxItem Content="Document3.txt"/>
                    <ListBoxItem Content="Document4.txt"/>
                    <ListBoxItem Content="Document5.txt"/>
                </ListBox>
            </Grid>
        </Grid>
    </Grid>
</Window>
