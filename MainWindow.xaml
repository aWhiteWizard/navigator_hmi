<Window x:Class="navigator_hmi.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:navigator_hmi"
        mc:Ignorable="d"
        Title="NavigatorHMI" Height="1040" Width="1920">
    <Grid Background="White" ShowGridLines="True">
        <Grid.RowDefinitions>
            <RowDefinition Height="20"></RowDefinition>
            <RowDefinition Height="300"></RowDefinition>
            <RowDefinition Height="680"></RowDefinition>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="2" ShowGridLines="True">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"></ColumnDefinition>
                <ColumnDefinition Width="1520"></ColumnDefinition>
            </Grid.ColumnDefinitions>
        </Grid>
        <Menu>
            <MenuItem Header="文件(N)" Background="White" BorderBrush="White">
                <Button x:Uid="0" x:Name="新建">    </Button>
            </MenuItem>
            <MenuItem Header="查询(N)" Background="White" BorderBrush="White"></MenuItem>
            <MenuItem Header="撤销(N)" Background="White" BorderBrush="White"></MenuItem>
            <MenuItem Header="帮助(N)" Background="White" BorderBrush="White"></MenuItem>
        </Menu>
        <StackPanel Orientation="Vertical" Grid.Row="2">
            <Button Background="White" Width="400" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top" BorderBrush="Gray">新建一个工程</Button>
            <Button Background="White" Width="400" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top" BorderBrush="Gray">最近编辑的工程</Button>
            <Button Background="White" Width="400" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top" BorderBrush="Gray">触摸屏维护</Button>
            <Button Background="White" Width="400" Height="40" HorizontalAlignment="Left" VerticalAlignment="Top" BorderBrush="Gray">更多信息</Button>
        </StackPanel>
    </Grid>
</Window>
